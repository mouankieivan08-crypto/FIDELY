# Supabase — get these from your project: Project Settings > API.
# Both URL values are the same; the two keys are different.

# Server-side (server.ts / src/lib/supabase-server.ts). The secret key
# bypasses Row Level Security — never expose it to the client.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SECRET_KEY="sb_secret_..."

# Client-side (src/lib/supabase.ts), exposed to the browser bundle by Vite.
# The publishable key is safe to expose — it's the whole point of RLS.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
