# Supabase — get these from your project: Project Settings > API.
# Both URL values are the same; the two keys are different.

# Server-side (server.ts / src/lib/supabase-server.ts). The secret key
# bypasses Row Level Security — never expose it to the client.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SECRET_KEY="sb_secret_..."

# Client-side (src/lib/supabase.ts), exposed to the browser bundle by Vite.
# The publishable key is safe to expose — it's the whole point of RLS.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# WhatsApp Business Cloud API (Meta) — laisser vide désactive complètement les
# notifications (src/lib/whatsapp.ts devient un no-op). À renseigner une fois le
# compte Meta Business vérifié et le numéro WhatsApp approuvé.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WELCOME_ENABLED=false
WHATSAPP_INACTIVE_REMINDER_ENABLED=false
# Secret partagé pour sécuriser la route /api/cron/inactive-reminders (à ajouter
# dans vercel.json > crons séparément, une fois validé avec le client).
CRON_SECRET=
